    "cross-env": "~7.0.3",
    "css-loader": "~6.8.1",
    "cssnano": "~6.0.3",
    "es-check": "~7.1.1",
    "eslint": "~8.56.0",
    "eslint-mdx": "~2.3.2",
    "eslint-plugin-mdx": "~2.3.2",
    "eslint-plugin-storybook": "~0.6.15",
    "jest": "~29.7.0",
    "jest-axe": "~8.0.0",
    "lint-all": "workspace:~",
    "lint-staged": "~15.2.0",
    "mini-css-extract-plugin": "~2.7.6",
