    "react-virtuoso": "~4.6.2",
    "resolve-url-loader": "~5.0.0",
    "rimraf": "~5.0.5",
    "sass": "~1.69.7",
    "sass-loader": "~13.3.3",
    "storybook": "~7.6.7",
    "storybook-dark-mode": "~3.0.3",
    "style-loader": "~3.3.3",
    "stylelint": "~16.1.0",
    "stylelint-order": "~6.0.4",
    "stylelint-prettier": "~5.0.0",
    "stylelint-scss": "~6.0.0",
    "testing-utils": "workspace:~",
    "ts-jest": "~29.1.1",
    "ts-loader": "~9.5.1",
    "typescript": "~5.3.3",
    "webpack": "~5.89.0",
    "webpack-bundle-analyzer": "~4.10.1",
