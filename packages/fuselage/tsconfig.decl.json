{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "noEmit": false,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "react-native": ["./src/react-native-shim.d.ts"]
    }
  }
}
