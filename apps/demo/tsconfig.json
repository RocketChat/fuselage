{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@rocket.chat/fuselage": ["../../packages/fuselage/src/index.ts"],
      "@rocket.chat/fuselage/*": ["../../packages/fuselage/src/*"],
      "@rocket.chat/fuselage-ui": ["../../packages/fuselage-ui/src/index.ts"],
      "@rocket.chat/fuselage-admin": ["../../packages/fuselage-admin/src/index.ts"]
    }
  },
  "include": ["src"]
}
