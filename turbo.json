{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!*.api.md"],
      "outputs": ["dist/**", "storybook-static/**", "*.api.md"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "docs": {
      "dependsOn": ["build"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "visual-regression": {
      "dependsOn": ["^build-storybook"],
      "outputs": []
    },
    "visual-regression-update": {
      "dependsOn": ["^build-storybook"],
      "outputs": []
    }
  }
}
